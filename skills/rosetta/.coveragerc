# Coverage config for the test suite. coverage.py is a CI/dev-only tool — it is NOT a runtime
# dependency of the skill (the shipped CLI stays pure stdlib, per ADR 0013). Run from skills/rosetta:
#   coverage run -m unittest discover -s tests && coverage report
[run]
branch = True
source =
    scripts
    evals/adversarial
# One-shot fixture/corpus generators are experiment apparatus, not maintained product code: each is run
# once to emit a fixture set and is never imported by a test (the fixtures they produce ARE tested, via
# run_evals.py / the Tier-A suite). They are omitted so the gate measures the shipped, maintained code
# (scripts/*, score.py, report.py, measure_tokens.py, fixtures.py, run_evals.py) rather than dead-on-
# arrival generator branches that would only ever be "covered" by re-running a completed experiment.
omit =
    evals/adversarial/goal1_fixture_gen.py
    evals/adversarial/goal2_gen.py
    evals/adversarial/scale_fixture_gen.py
    evals/adversarial/scale_fixture_gen_v4.py
    evals/adversarial/scale_fixture_gen_v5.py
    evals/adversarial/phase0_alias_retriever.py
    evals/adversarial/killtest_gen.py
    evals/adversarial/killtest_validate.py
    evals/adversarial/killtest_smoke.py
    # Adversarial kill-test / cross-harness RUNNERS are the same class of one-shot experiment
    # apparatus as the *_gen.py generators above: standalone entry points, never imported by a
    # test (verified — each drives an external harness / subprocess). Omitted on the same grounds.
    evals/adversarial/killtest_adversarial.py
    evals/adversarial/killtest_agentic.py
    evals/adversarial/killtest_compile.py
    evals/adversarial/killtest_matrix.py
    evals/adversarial/killtest_scale.py

[report]
fail_under = 90
show_missing = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    sys.exit\(main\(\)\)
