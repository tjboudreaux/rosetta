  "recommended_fields": ["Sources"],
  "optional_fields": ["Decided originally", "Related", "Supersedes"],
  "record_types": {
    "adr": {
      "label": "ADR",
      "name": "Architecture Decision Record",
      "dir": "architecture-decisions",
      "template": "templates/adr-template.md"
    },
    "pdr": {
      "label": "PDR",
      "name": "Product Decision Record",
      "dir": "product-decisions",
      "template": "templates/pdr-template.md"
    },
    "bdr": {
      "label": "BDR",
      "name": "Business Decision Record",
      "dir": "business-decisions",
      "template": "templates/bdr-template.md"
    }
  },
  "index": {
    "path": "README.md",
    "columns": ["Date", "ID", "Type", "Decision", "Status"]
  }
}
